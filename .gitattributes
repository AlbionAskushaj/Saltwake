# Normalize text files in this repository to LF to avoid safecrlf errors.
* text=auto eol=lf

# Unity/project text assets
*.cs text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.compute text eol=lf
*.uxml text eol=lf
*.uss text eol=lf
*.asmdef text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.meta text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.asset text eol=lf

# Keep Windows command scripts with CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
